YURA_CHESS_ENVIRONMENT=development
YURA_CHESS_HOST=0.0.0.0
YURA_CHESS_PORT=8000
# Server-side salt for pseudonymised owner keys; generate per environment and never commit the real value.
YURA_CHESS_IDENTITY_SALT=change-me-identity-salt
YURA_CHESS_WEBHOOK_DEADLINE_SECONDS=4.5
YURA_CHESS_DATABASE_URL=mysql+pymysql://yura_chess:change-me@127.0.0.1:3307/yura_chess?charset=utf8mb4
YURA_CHESS_STOCKFISH_PATH=/usr/games/stockfish
YURA_CHESS_ENGINE_POOL_SIZE=2
YURA_CHESS_ENGINE_THREADS=1
YURA_CHESS_ENGINE_HASH_MB=64
YURA_CHESS_ENGINE_SKILL_LEVEL=5
YURA_CHESS_ENGINE_ACQUIRE_TIMEOUT_SECONDS=0.5
YURA_CHESS_ENGINE_MOVE_DEADLINE_SECONDS=3.0
YURA_CHESS_ENGINE_MOVE_TIME_SECONDS=1.0
YURA_CHESS_ENGINE_RESTART_DELAY_SECONDS=1.0
# Analysis runs on top of a normal answer, so it gets a shorter deadline than a move.
YURA_CHESS_ENGINE_ANALYSIS_DEADLINE_SECONDS=1.5
YURA_CHESS_ENGINE_ANALYSIS_TIME_SECONDS=0.5
YURA_CHESS_ENGINE_ANALYSIS_CANDIDATES=3

# Screen card. Without the Dialogs credentials the skill stays voice-only.
YURA_CHESS_BOARD_IMAGE_ENABLED=true
YURA_CHESS_YANDEX_SKILL_ID=
YURA_CHESS_YANDEX_OAUTH_TOKEN=
YURA_CHESS_IMAGE_UPLOAD_TIMEOUT_SECONDS=1.0
YURA_CHESS_BOARD_IMAGE_TTL_DAYS=7
YURA_CHESS_BOARD_IMAGE_CACHE_LIMIT=2000
YURA_CHESS_BOARD_IMAGE_CACHE_BURST=500
YURA_CHESS_BOARD_IMAGE_CLEANUP_BATCH_SIZE=50
YURA_CHESS_BOARD_IMAGE_CLEANUP_GRACE_SECONDS=300
YURA_CHESS_BOARD_IMAGE_QUOTA_STOP_RATIO=0.8
YURA_CHESS_ASR_TRANSCRIPT_RETENTION_DAYS=30
YURA_CHESS_ASR_TRANSCRIPT_TEXT_LIMIT=255
YURA_CHESS_REQUEST_REPLAY_RETENTION_DAYS=7
YURA_CHESS_MAINTENANCE_INTERVAL_SECONDS=60

# Repository integration tests run against a real MariaDB and are skipped without this DSN.
YURA_CHESS_TEST_DATABASE_URL=mysql+pymysql://root:change-me-too@127.0.0.1:3307/yura_chess_test?charset=utf8mb4

# Firebat backups (deploy/mariadb/*.sh only; the application never reads these).
# Real values live in /srv/yura-chess/backup.env on Firebat and are never committed.
YURA_CHESS_COMPOSE_PROJECT=yura-chess-production
YURA_CHESS_COMPOSE_FILE=/srv/yura-chess/repo/deploy/compose.production.yml
YURA_CHESS_DB_NAME=yura_chess
YURA_CHESS_BACKUP_DB_USER=yura_chess_backup
YURA_CHESS_BACKUP_DB_PASSWORD=
YURA_CHESS_RESTORE_DB_USER=root
YURA_CHESS_RESTORE_DB_PASSWORD=
YURA_CHESS_BACKUP_DIR=/srv/yura-chess/backups
YURA_CHESS_BACKUP_RETENTION_DAYS=14
YURA_CHESS_BACKUP_MIN_FREE_MB=2048
# Without an off-host target a backup does not survive the loss of Firebat.
YURA_CHESS_BACKUP_S3_TARGET=
YURA_CHESS_BACKUP_S3_ENDPOINT=
YURA_CHESS_BACKUP_ALERT_COMMAND=

# Deployment (deploy/deploy.sh, deploy/rollback.sh)
YURA_CHESS_IMAGE_REPOSITORY=ghcr.io/blaryxoff/yura-chess
YURA_CHESS_STATE_DIR=/srv/yura-chess

# Local docker-compose MariaDB service
MARIADB_DATABASE=yura_chess
MARIADB_USER=yura_chess
MARIADB_PASSWORD=change-me
MARIADB_ROOT_PASSWORD=change-me-too
MARIADB_PORT=3307
