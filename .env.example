YURA_CHESS_ENVIRONMENT=development
YURA_CHESS_HOST=0.0.0.0
YURA_CHESS_PORT=8000
YURA_CHESS_DATABASE_URL=mysql+pymysql://yura_chess:change-me@127.0.0.1:3307/yura_chess?charset=utf8mb4
YURA_CHESS_STOCKFISH_PATH=/usr/games/stockfish

# Repository integration tests run against a real MariaDB and are skipped without this DSN.
YURA_CHESS_TEST_DATABASE_URL=mysql+pymysql://root:change-me-too@127.0.0.1:3307/yura_chess_test?charset=utf8mb4

# Local docker-compose MariaDB service
MARIADB_DATABASE=yura_chess
MARIADB_USER=yura_chess
MARIADB_PASSWORD=change-me
MARIADB_ROOT_PASSWORD=change-me-too
MARIADB_PORT=3307
